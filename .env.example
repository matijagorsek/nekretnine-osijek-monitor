TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CRON_SCHEDULE=0 12 * * *
DB_PATH=./data/listings.db
FILTER_CITY=osijek
FILTER_TYPE=all
FILTER_PRICE_MIN=0
FILTER_PRICE_MAX=200000
FILTER_SIZE_MIN=0
FILTER_SIZE_MAX=500
FILTER_ROOMS_MIN=0
FILTER_ROOMS_MAX=10
FILTER_LOCATIONS=
DEDUPE_THRESHOLD=0.85

# User-defined notification triggers (JSON array; overrides global filter for notifications)
# Each trigger: { "name": "string", "type": "all|stan|kuca", "priceMin": 0, "priceMax": 200000,
#                 "sizeMin": 0, "sizeMax": 500, "roomsMin": 0, "roomsMax": 10, "locations": [] }
# Example: [{"name":"Centar jeftino","priceMax":80000,"locations":["centar"]},{"name":"Velika kuća","type":"kuca","sizeMin":150}]
NOTIFICATION_TRIGGERS=

# Custom scrapers (JSON array; add any real estate website by providing CSS selectors)
# Each entry: { "name": "string", "url": "https://...", "city": "osijek",
#               "selectors": { "item": ".listing", "link": "a", "title": "h2", "price": ".price" } }
# Example: [{"name":"My Agency","url":"https://example.com/nekretnine?grad=osijek","city":"osijek","selectors":{"item":".oglas","link":"a","title":"h3","price":".cijena"}}]
CUSTOM_SCRAPERS=

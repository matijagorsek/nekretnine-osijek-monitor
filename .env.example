TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CRON_SCHEDULE=0 12 * * *
WEEKLY_DIGEST_CRON=0 9 * * 0
DB_PATH=./data/listings.db
# Comma-separated list of cities to monitor (e.g. osijek,zagreb,split)
CITIES=osijek
FILTER_CITY=osijek
FILTER_TYPE=all
FILTER_PRICE_MIN=0
FILTER_PRICE_MAX=200000
FILTER_SIZE_MIN=0
FILTER_SIZE_MAX=500
FILTER_ROOMS_MIN=0
FILTER_ROOMS_MAX=10
FILTER_LOCATIONS=
DEDUPE_THRESHOLD=0.85
NOTIFY_MODE=instant
DIGEST_HOUR=8

# Alert thresholds: minimum price drop required to trigger a price-drop notification
# ALERT_PRICE_DROP_MIN_PCT=0    # minimum % drop (e.g. 5 = only notify if price drops ≥5%)
# ALERT_PRICE_DROP_MIN_EUR=0    # minimum EUR drop (e.g. 2000 = only notify if price drops ≥2000€)
ALERT_PRICE_DROP_MIN_PCT=0
ALERT_PRICE_DROP_MIN_EUR=0

# Quiet hours — suppress all notifications in this window (24h format, e.g. 22:00–07:00)
# Leave blank to disable quiet hours
QUIET_HOURS_START=
QUIET_HOURS_END=

# User-defined notification triggers (JSON array; overrides global filter for notifications)
# Each trigger: { "name": "string", "type": "all|stan|kuca", "priceMin": 0, "priceMax": 200000,
#                 "sizeMin": 0, "sizeMax": 500, "roomsMin": 0, "roomsMax": 10, "locations": [] }
# Example: [{"name":"Centar jeftino","priceMax":80000,"locations":["centar"]},{"name":"Velika kuća","type":"kuca","sizeMin":150}]
NOTIFICATION_TRIGGERS=

# Custom scrapers (JSON array; add any real estate website by providing CSS selectors)
# Each entry: { "name": "string", "url": "https://...", "city": "osijek",
#               "selectors": { "item": ".listing", "link": "a", "title": "h2", "price": ".price" } }
# Example: [{"name":"My Agency","url":"https://example.com/nekretnine?grad=osijek","city":"osijek","selectors":{"item":".oglas","link":"a","title":"h3","price":".cijena"}}]
CUSTOM_SCRAPERS=

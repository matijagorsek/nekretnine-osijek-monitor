# Notification channels (comma-separated: telegram, email, webhook)
# Default: telegram
NOTIFICATION_CHANNELS=telegram

# Telegram Bot (required if telegram is in NOTIFICATION_CHANNELS)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email (required if email is in NOTIFICATION_CHANNELS)
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your_smtp_user
EMAIL_SMTP_PASS=your_smtp_password
EMAIL_FROM=monitor@example.com
EMAIL_TO=you@example.com

# Webhook (required if webhook is in NOTIFICATION_CHANNELS)
# Receives POST requests with JSON: { event, timestamp, data }
WEBHOOK_URL=https://your-webhook-endpoint.example.com/notify
# Optional: sent as X-Webhook-Secret header for receiver-side validation
WEBHOOK_SECRET=

# Schedule (cron format) - default: every day at 12:00
CRON_SCHEDULE=0 12 * * *
DB_PATH=./data/listings.db

# Cities to monitor (comma-separated; supported: osijek, zagreb, split, rijeka, zadar, pula)
CITIES=osijek

# Filters
FILTER_CITY=osijek
FILTER_TYPE=all
FILTER_PRICE_MIN=0
FILTER_PRICE_MAX=200000
FILTER_SIZE_MIN=0
FILTER_SIZE_MAX=500
FILTER_ROOMS_MIN=0
FILTER_ROOMS_MAX=10
FILTER_LOCATIONS=
DEDUPE_THRESHOLD=0.85

# User-defined notification triggers (JSON array; overrides global filter for notifications)
# Each trigger: { "name": "string", "type": "all|stan|kuca", "priceMin": 0, "priceMax": 200000,
#                 "sizeMin": 0, "sizeMax": 500, "roomsMin": 0, "roomsMax": 10, "locations": [] }
# Example: [{"name":"Centar jeftino","priceMax":80000,"locations":["centar"]},{"name":"Velika kuća","type":"kuca","sizeMin":150}]
NOTIFICATION_TRIGGERS=
